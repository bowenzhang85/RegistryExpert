<Window x:Class="RegistryExpert.Wpf.Views.AnalyzeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RegistryExpert.Wpf.ViewModels"
        xmlns:helpers="clr-namespace:RegistryExpert.Wpf.Helpers"
        Title="Analyze Registry"
        Width="1100" Height="700"
        MinWidth="900" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Style="{DynamicResource ModernWindowStyle}"
        ShowInTaskbar="True">

    <Window.Resources>
        <helpers:ContentModeToVisibilityConverter x:Key="ModeToVis" />
        <helpers:GridColumnCountToVisibilityConverter x:Key="ColCountToVis" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Converters (must be declared before templates that reference them) -->
        <helpers:BoolToDoubleConverter x:Key="EnabledToOpacityConverter" TrueValue="1.0" FalseValue="0.35" />
        <helpers:BoolToForegroundConverter x:Key="EnabledToForegroundConverter" />
        <helpers:BindingProxy x:Key="Proxy" Data="{Binding}" />

        <!-- Shared firewall direction toggle button style -->
        <Style x:Key="FirewallToggleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SurfaceLightBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SelectionBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Category ListBox item template -->
        <DataTemplate x:Key="CategoryItemTemplate" DataType="{x:Type vm:AnalyzeViewModel+CategoryItem}">
            <Grid Height="42" Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Source="{Binding IconPath}"
                       Width="28" Height="28"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Opacity="{Binding IsEnabled, Converter={StaticResource EnabledToOpacityConverter}}" />
                <TextBlock Grid.Column="1" Text="{Binding Name}"
                           VerticalAlignment="Center"
                           FontSize="13" FontWeight="SemiBold"
                           Margin="4,0,8,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </DataTemplate>

        <!-- Subcategory button template -->
        <DataTemplate x:Key="SubcategoryButtonTemplate" DataType="{x:Type vm:AnalyzeViewModel+SubcategoryItem}">
            <Button Command="{Binding SelectCommand}"
                    Content="{Binding Title}"
                    ToolTip="{Binding Tooltip}"
                    IsEnabled="{Binding IsEnabled}"
                    Style="{DynamicResource SubcategoryButtonStyle}"
                    Tag="{Binding IsActive}"
                    Margin="0,0,4,4" />
        </DataTemplate>
    </Window.Resources>

    <!-- Main layout: left categories + right content -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="150" />
            <ColumnDefinition Width="3" />
            <ColumnDefinition Width="*" MinWidth="300" />
        </Grid.ColumnDefinitions>

        <!-- ═══ Left Panel: Categories ═══ -->
        <Border Grid.Column="0"
                Background="{DynamicResource BackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,0">
            <DockPanel>
                <!-- Categories header -->
                <Border DockPanel.Dock="Top"
                        Style="{DynamicResource SectionHeaderBorderStyle}">
                    <TextBlock Text="Categories"
                               Style="{DynamicResource SectionHeaderStyle}"
                               Padding="0" />
                </Border>

                <!-- Category list -->
                <ListBox x:Name="CategoryList"
                         ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         ItemTemplate="{StaticResource CategoryItemTemplate}"
                         Background="{DynamicResource BackgroundBrush}"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                            <Setter Property="ToolTip" Value="{Binding Tooltip}" />
                            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
                            <Setter Property="Padding" Value="4,0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="Transparent"
                                                BorderThickness="3,0,0,0"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource SurfaceHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource SelectionBrush}" />
                                                <Setter TargetName="Bd" Property="BorderBrush"
                                                        Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" />

        <!-- ═══ Right Panel: Content ═══ -->
        <Grid Grid.Column="2" Background="{DynamicResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- Content header -->
                <RowDefinition Height="Auto" />  <!-- Subcategory bar -->
                <RowDefinition Height="*" />     <!-- Content area -->
                <RowDefinition Height="3" />     <!-- Splitter -->
                <RowDefinition Height="150" />   <!-- Detail pane -->
            </Grid.RowDefinitions>

            <!-- Content Header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <TextBlock Text="{Binding ContentHeader}"
                           Style="{DynamicResource HeaderStyle}" />
            </Border>

            <!-- Subcategory buttons bar + sub-tab bar -->
            <StackPanel Grid.Row="1">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="8,4"
                        Visibility="{Binding ShowSubcategories, Converter={StaticResource BoolToVis}}">
                    <DockPanel LastChildFill="True">
                        <!-- Services search box (right-aligned, only visible for Services) -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="12,0,4,0"
                                    Visibility="{Binding ShowServiceSearch, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Search:" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,6,0" />
                            <TextBox Text="{Binding ServiceSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="200" Padding="6,3"
                                     VerticalAlignment="Center"
                                     FontSize="12" />
                        </StackPanel>
                        <!-- Subcategory filter buttons -->
                        <ItemsControl ItemsSource="{Binding Subcategories}"
                                      ItemTemplate="{StaticResource SubcategoryButtonTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <!-- Sub-tab bar (secondary filter buttons within a subcategory) -->
                <Border Background="{DynamicResource SurfaceLightBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,4"
                        Visibility="{Binding ShowSubTabs, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding SubTabs}"
                                  ItemTemplate="{StaticResource SubcategoryButtonTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Border>

                <!-- CBS Packages search bar (DISM checkbox + search box, only visible on All Packages sub-tab) -->
                <Border Background="{DynamicResource SurfaceLightBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,4"
                        Visibility="{Binding ShowCbsSearch, Converter={StaticResource BoolToVis}}">
                    <DockPanel LastChildFill="True">
                        <!-- Search box (right-aligned) -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="12,0,4,0">
                            <TextBlock Text="Search:" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,6,0" />
                            <TextBox Text="{Binding CbsSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="200" Padding="6,3"
                                     VerticalAlignment="Center"
                                     FontSize="12" />
                        </StackPanel>
                        <!-- DISM /Get-Package checkbox (left-aligned) -->
                        <CheckBox IsChecked="{Binding CbsDismFilter}"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  Margin="4,0,0,0">
                            <TextBlock Text="DISM /Get-Package"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </CheckBox>
                    </DockPanel>
                </Border>

                <!-- Info banner (e.g., "Load a SYSTEM hive to detect additional security products") -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,5">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding InfoBannerText}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding InfoBannerText}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11.5"
                               FontStyle="Italic" />
                </Border>
            </StackPanel>

            <!-- ═══ Content Area (overlapping panels, visibility-toggled) ═══ -->
            <Grid Grid.Row="2">

                <!-- Default Grid View -->
                <DataGrid x:Name="DefaultGrid"
                          ItemsSource="{Binding DefaultGridRows}"
                          SelectedItem="{Binding SelectedGridRow}"
                          Visibility="{Binding CurrentMode, Converter={StaticResource ModeToVis}, ConverterParameter=DefaultGrid}"
                          AlternationCount="2"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="2*" MinWidth="120"
                                                Header="{Binding Data.GridColumn1Header, Source={StaticResource Proxy}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Column1}"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="3*"
                                                Header="{Binding Data.GridColumn2Header, Source={StaticResource Proxy}}"
                                                Visibility="{Binding Data.GridColumnCount, Source={StaticResource Proxy}, Converter={StaticResource ColCountToVis}, ConverterParameter=2}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Column2}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*"
                                                Header="{Binding Data.GridColumn3Header, Source={StaticResource Proxy}}"
                                                Visibility="{Binding Data.GridColumnCount, Source={StaticResource Proxy}, Converter={StaticResource ColCountToVis}, ConverterParameter=3}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Column3}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*"
                                                Header="{Binding Data.GridColumn4Header, Source={StaticResource Proxy}}"
                                                Visibility="{Binding Data.GridColumnCount, Source={StaticResource Proxy}, Converter={StaticResource ColCountToVis}, ConverterParameter=4}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Column4}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*"
                                                Header="{Binding Data.GridColumn5Header, Source={StaticResource Proxy}}"
                                                Visibility="{Binding Data.GridColumnCount, Source={StaticResource Proxy}, Converter={StaticResource ColCountToVis}, ConverterParameter=5}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Column5}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource WarningTextBrush}" />
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsSubSection}" Value="True" />
                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                </MultiDataTrigger>
                                <DataTrigger Binding="{Binding IsHealthy}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource HealthyTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>

                <!-- Placeholder for specialized views (Tasks 11-12) -->
                <TextBlock Text="(View not yet implemented)"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextDisabledBrush}"
                           FontSize="14">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static vm:ContentMode.CbsPackages}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static vm:ContentMode.ComponentsOverview}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- ═══ Roles & Features View ═══ -->
                <Grid Visibility="{Binding CurrentMode, Converter={StaticResource ModeToVis}, ConverterParameter=RolesFeatures}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" MinWidth="150" />
                        <ColumnDefinition Width="3" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Roles/Features tree -->
                    <DockPanel Grid.Column="0">
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="8,4"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding RolesTreeHeader}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <TreeView ItemsSource="{Binding RolesFeatureNodes}"
                                  SelectedItemChanged="RolesTree_SelectedItemChanged"
                                  Background="{DynamicResource BackgroundBrush}"
                                  BorderThickness="0">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type vm:AnalyzeViewModel+DeviceTreeNode}"
                                                          ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding DisplayName}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ForegroundBrushKey}" Value="TextDisabledBrush">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </DockPanel>

                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" />

                    <!-- Role/Feature details grid -->
                    <DockPanel Grid.Column="2">
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="8,4"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding RoleFeatureDetailHeader}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <DataGrid ItemsSource="{Binding RoleFeatureDetails}"
                                  SelectedItem="{Binding SelectedRoleFeatureDetail}"
                                  AlternationCount="2"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Property" Width="200" MinWidth="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Column1}"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Value" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Column2}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHealthy}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource HealthyTextBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </DockPanel>
                </Grid>

                <!-- ═══ Disk Partitions (Mounted Devices) View ═══ -->
                <Grid Visibility="{Binding CurrentMode, Converter={StaticResource ModeToVis}, ConverterParameter=DiskPartitions}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" MinWidth="150" />
                        <ColumnDefinition Width="3" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Mounted devices list -->
                    <DockPanel Grid.Column="0">
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="8,4"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="Mounted Devices"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <DataGrid ItemsSource="{Binding MountedDevices}"
                                  SelectedItem="{Binding SelectedMountedDevice}"
                                  AlternationCount="2"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Mount Point" Width="120" MinWidth="80"
                                                        SortMemberPath="MountPoint">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding MountPoint}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Device" Width="*"
                                                        SortMemberPath="FriendlyName">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FriendlyName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StaleStatus}" Value="Stale">
                                            <Setter Property="Foreground" Value="{DynamicResource WarningTextBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </DockPanel>

                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" />

                    <!-- Device detail grid -->
                    <DockPanel Grid.Column="2">
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="8,4"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding MountedDeviceDetailHeader}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <DataGrid ItemsSource="{Binding MountedDeviceDetails}"
                                  SelectedItem="{Binding SelectedMountedDeviceDetail}"
                                  AlternationCount="2"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Property" Width="200" MinWidth="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Column1}"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Value" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Column2}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSubSection}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold" />
                                            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource WarningTextBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </DockPanel>
                </Grid>

                <!-- ═══ Physical Disks View ═══ -->
                <Grid Visibility="{Binding CurrentMode, Converter={StaticResource ModeToVis}, ConverterParameter=PhysicalDisks}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" MinWidth="150" />
                        <ColumnDefinition Width="3" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Physical disks list -->
                    <DockPanel Grid.Column="0">
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="8,4"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="Physical Disks"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <DataGrid ItemsSource="{Binding PhysicalDisksList}"
                                  SelectedItem="{Binding SelectedPhysicalDisk}"
                                  AlternationCount="2"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Disk" Width="*" MinWidth="120"
                                                        SortMemberPath="FriendlyName">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FriendlyName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Bus Type" Width="90"
                                                        SortMemberPath="BusType">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding BusType}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Status" Width="120"
                                                        SortMemberPath="PoolStatus">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding PoolStatus}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PoolStatus}" Value="Probable Pool Member">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </DockPanel>

                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" />

                    <!-- Physical disk detail grid -->
                    <DockPanel Grid.Column="2">
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="8,4"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding PhysicalDiskDetailHeader}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <DataGrid ItemsSource="{Binding PhysicalDiskDetails}"
                                  SelectedItem="{Binding SelectedPhysicalDiskDetail}"
                                  AlternationCount="2"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Property" Width="200" MinWidth="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Column1}"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Value" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Column2}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSubSection}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold" />
                                            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource WarningTextBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </DockPanel>
                </Grid>

                <!-- ═══ Services View ═══ -->
                <DataGrid x:Name="ServicesGrid"
                          ItemsSource="{Binding FilteredServices}"
                          SelectedItem="{Binding SelectedService}"
                          Visibility="{Binding CurrentMode, Converter={StaticResource ModeToVis}, ConverterParameter=Services}"
                          AlternationCount="2"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Service Name" Width="*" MinWidth="160"
                                                SortMemberPath="ServiceName">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ServiceName}"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Display Name" Width="*" MinWidth="160"
                                                SortMemberPath="DisplayName">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Start Type" Width="130"
                                                SortMemberPath="StartTypeName">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StartTypeName}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Image Path" Width="*"
                                                SortMemberPath="ImagePath">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ImagePath}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>

                <!-- ═══ Network Interfaces View (master-detail) ═══ -->
                <Grid Visibility="{Binding CurrentMode, Converter={StaticResource ModeToVis}, ConverterParameter=NetworkInterfaces}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" MinWidth="150" />
                        <ColumnDefinition Width="3" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Adapter list -->
                    <DockPanel Grid.Column="0">
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="8,4"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="Network Adapters"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <ListBox ItemsSource="{Binding NetworkAdapters}"
                                 SelectedItem="{Binding SelectedNetworkAdapter}"
                                 DisplayMemberPath="DisplayName"
                                 Background="{DynamicResource BackgroundBrush}"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                    </DockPanel>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" />

                    <!-- Properties grid -->
                    <DataGrid Grid.Column="2"
                              ItemsSource="{Binding NetworkProperties}"
                              SelectedItem="{Binding SelectedNetworkProperty}"
                              AlternationCount="2"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Property" Width="200" MinWidth="100"
                                                    SortMemberPath="Name">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="8,2" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Value" Width="*"
                                                    SortMemberPath="Value">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Value}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="8,2" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- ═══ Firewall View ═══ -->
                <Grid Visibility="{Binding CurrentMode, Converter={StaticResource ModeToVis}, ConverterParameter=Firewall}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />  <!-- Profile buttons -->
                        <RowDefinition Height="Auto" />  <!-- Direction toggle -->
                        <RowDefinition Height="*" />     <!-- Rules grid -->
                    </Grid.RowDefinitions>

                    <!-- Profile buttons row -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceBrush}"
                            Padding="8,6"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Select Profile:"
                                       FontWeight="SemiBold" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0" />
                            <ItemsControl ItemsSource="{Binding FirewallProfiles}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding SelectCommand}"
                                                Content="{Binding Label}"
                                                Margin="0,0,6,0"
                                                MinWidth="130"
                                                FontWeight="SemiBold">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource DiffAddedBrush}" />
                                                    <Setter Property="Padding" Value="10,4" />
                                                    <Setter Property="Cursor" Value="Hand" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd"
                                                                        Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="4"
                                                                        Padding="{TemplateBinding Padding}"
                                                                        SnapsToDevicePixels="True">
                                                                    <TextBlock Text="{TemplateBinding Content}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background"
                                                                                Value="{DynamicResource SelectionBrush}" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <!-- Disabled profile: red text -->
                                                        <DataTrigger Binding="{Binding IsProfileEnabled}" Value="False">
                                                            <Setter Property="Foreground" Value="{DynamicResource DiffRemovedBrush}" />
                                                        </DataTrigger>
                                                        <!-- Active/selected profile: accent background, keep red/green text -->
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Direction buttons row -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource SurfaceBrush}"
                            Padding="8,4"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Direction:"
                                       FontWeight="SemiBold" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0" />
                            <!-- Inbound button -->
                            <Button Command="{Binding SetFirewallDirectionCommand}"
                                    CommandParameter="Inbound"
                                    Content="⬇ Inbound"
                                    Margin="0,0,6,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource FirewallToggleButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FirewallDirection}" Value="Inbound">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <!-- Outbound button -->
                            <Button Command="{Binding SetFirewallDirectionCommand}"
                                    CommandParameter="Outbound"
                                    Content="⬆ Outbound"
                                    Margin="0,0,12,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource FirewallToggleButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FirewallDirection}" Value="Outbound">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock Text="{Binding FirewallRulesHeader}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="4,0,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Rules DataGrid -->
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding FirewallRules}"
                              SelectedItem="{Binding SelectedFirewallRule}"
                              AlternationCount="2"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Status" Width="60"
                                                    SortMemberPath="IsActive">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="8,2">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="Text" Value="⬜" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Text" Value="✅" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Action" Width="90"
                                                    SortMemberPath="Action">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock TextTrimming="CharacterEllipsis" Margin="8,2">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="Text" Value="✓ Allow" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Action}" Value="Block">
                                                            <Setter Property="Text" Value="🚫 Block" />
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsActive}" Value="True" />
                                                                <Condition Binding="{Binding Action}" Value="Block" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Foreground" Value="{DynamicResource BlockRowForegroundBrush}" />
                                                        </MultiDataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Dir" Width="60"
                                                    SortMemberPath="Direction">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock TextTrimming="CharacterEllipsis" Margin="8,2">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="Text" Value="⬇ In" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Direction}" Value="Outbound">
                                                            <Setter Property="Text" Value="⬆ Out" />
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsActive}" Value="True" />
                                                                <Condition Binding="{Binding Action}" Value="Block" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Foreground" Value="{DynamicResource BlockRowForegroundBrush}" />
                                                        </MultiDataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Name" Width="*" MinWidth="200"
                                                    SortMemberPath="Name">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="8,2">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsActive}" Value="True" />
                                                                <Condition Binding="{Binding Action}" Value="Block" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Foreground" Value="{DynamicResource BlockRowForegroundBrush}" />
                                                        </MultiDataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Protocol" Width="80"
                                                    SortMemberPath="Protocol">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Protocol}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="8,2">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsActive}" Value="True" />
                                                                <Condition Binding="{Binding Action}" Value="Block" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Foreground" Value="{DynamicResource BlockRowForegroundBrush}" />
                                                        </MultiDataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Local Port" Width="100"
                                                    SortMemberPath="LocalPorts">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock TextTrimming="CharacterEllipsis" Margin="8,2">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="Text" Value="{Binding LocalPorts}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LocalPorts}" Value="">
                                                            <Setter Property="Text" Value="Any" />
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsActive}" Value="True" />
                                                                <Condition Binding="{Binding Action}" Value="Block" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Foreground" Value="{DynamicResource BlockRowForegroundBrush}" />
                                                        </MultiDataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Remote Port" Width="100"
                                                    SortMemberPath="RemotePorts">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock TextTrimming="CharacterEllipsis" Margin="8,2">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="Text" Value="{Binding RemotePorts}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RemotePorts}" Value="">
                                                            <Setter Property="Text" Value="Any" />
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsActive}" Value="True" />
                                                                <Condition Binding="{Binding Action}" Value="Block" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Foreground" Value="{DynamicResource BlockRowForegroundBrush}" />
                                                        </MultiDataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Application" Width="*"
                                                    SortMemberPath="Application">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Application}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="8,2">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsActive}" Value="True" />
                                                                <Condition Binding="{Binding Action}" Value="Block" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Foreground" Value="{DynamicResource BlockRowForegroundBrush}" />
                                                        </MultiDataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <Style.Triggers>
                                    <!-- Active block rules: red highlight -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsActive}" Value="True" />
                                            <Condition Binding="{Binding Action}" Value="Block" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Background" Value="{DynamicResource BlockRowBackgroundBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource BlockRowForegroundBrush}" />
                                    </MultiDataTrigger>
                                    <!-- Inactive rules: dimmed -->
                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </Grid>

                <!-- ═══ Device Manager View ═══ -->
                <Grid Visibility="{Binding CurrentMode, Converter={StaticResource ModeToVis}, ConverterParameter=DeviceManager}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" MinWidth="150" />
                        <ColumnDefinition Width="3" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Device class/device tree -->
                    <DockPanel Grid.Column="0">
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="8,4"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="Device Classes"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <TreeView ItemsSource="{Binding DeviceManagerNodes}"
                                  SelectedItemChanged="DeviceManagerTree_SelectedItemChanged"
                                  Background="{DynamicResource BackgroundBrush}"
                                  BorderThickness="0">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type vm:AnalyzeViewModel+DeviceTreeNode}"
                                                          ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding DisplayName}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ForegroundBrushKey}" Value="ErrorBrush">
                                                        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ForegroundBrushKey}" Value="TextDisabledBrush">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </DockPanel>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" />

                    <!-- Right panel: Properties/Driver tabs -->
                    <DockPanel Grid.Column="2">
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="8,4"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding DeviceDetailHeader}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <!-- Device detail toggle buttons -->
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="8,4">
                            <ItemsControl ItemsSource="{Binding DeviceDetailTabs}"
                                          ItemTemplate="{StaticResource SubcategoryButtonTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </Border>

                        <!-- Device Properties DataGrid -->
                        <Grid>
                            <DataGrid ItemsSource="{Binding DeviceProperties}"
                                      SelectedItem="{Binding SelectedDeviceProperty}"
                                      AlternationCount="2"
                                      HeadersVisibility="Column"
                                      Visibility="{Binding IsDevicePropertiesTabActive, Converter={StaticResource BoolToVis}}">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Property" Width="200" MinWidth="100"
                                                            SortMemberPath="Name">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="8,2" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Value" Width="*"
                                                            SortMemberPath="Value">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Value}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="8,2" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Driver Details DataGrid -->
                            <DataGrid ItemsSource="{Binding DriverProperties}"
                                      SelectedItem="{Binding SelectedDriverProperty}"
                                      AlternationCount="2"
                                      HeadersVisibility="Column"
                                      Visibility="{Binding IsDriverDetailsTabActive, Converter={StaticResource BoolToVis}}">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Property" Width="200" MinWidth="100"
                                                            SortMemberPath="Name">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="8,2" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Value" Width="*"
                                                            SortMemberPath="Value">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Value}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="8,2" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </DockPanel>
                </Grid>

                <!-- ═══ Scheduled Tasks View ═══ -->
                <Grid Visibility="{Binding CurrentMode, Converter={StaticResource ModeToVis}, ConverterParameter=ScheduledTasks}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" MinWidth="150" />
                        <ColumnDefinition Width="3" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Task folders tree -->
                    <DockPanel Grid.Column="0">
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="8,4"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding ScheduledTasksHeader}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <TreeView ItemsSource="{Binding ScheduledTaskNodes}"
                                  SelectedItemChanged="ScheduledTasksTree_SelectedItemChanged"
                                  Background="{DynamicResource BackgroundBrush}"
                                  BorderThickness="0">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type vm:AnalyzeViewModel+ScheduledTaskTreeNode}"
                                                          ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding DisplayName}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ForegroundBrushKey}" Value="ErrorBrush">
                                                        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ForegroundBrushKey}" Value="TextDisabledBrush">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </DockPanel>

                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" />

                    <!-- Task details grid -->
                    <DockPanel Grid.Column="2">
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="8,4"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding ScheduledTaskDetailHeader}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <DataGrid ItemsSource="{Binding ScheduledTaskDetails}"
                                  SelectedItem="{Binding SelectedScheduledTaskDetail}"
                                  AlternationCount="2"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Property" Width="200" MinWidth="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Column1}"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Value" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Column2}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>

                <!-- ═══ Certificate Stores View ═══ -->
                <Grid Visibility="{Binding CurrentMode, Converter={StaticResource ModeToVis}, ConverterParameter=CertificateStores}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" MinWidth="150" />
                        <ColumnDefinition Width="3" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Stores/certificates tree -->
                    <DockPanel Grid.Column="0">
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="8,4"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding CertStoresTreeHeader}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <TreeView ItemsSource="{Binding CertStoreNodes}"
                                  SelectedItemChanged="CertStoresTree_SelectedItemChanged"
                                  Background="{DynamicResource BackgroundBrush}"
                                  BorderThickness="0">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type vm:AnalyzeViewModel+ScheduledTaskTreeNode}"
                                                          ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding DisplayName}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ForegroundBrushKey}" Value="ErrorBrush">
                                                        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ForegroundBrushKey}" Value="TextDisabledBrush">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </DockPanel>

                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" />

                    <!-- Certificate details grid -->
                    <DockPanel Grid.Column="2">
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="8,4"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding CertStoreDetailHeader}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <DataGrid ItemsSource="{Binding CertificateDetails}"
                                  SelectedItem="{Binding SelectedCertificateDetail}"
                                  AlternationCount="2"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Property" Width="200" MinWidth="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Column1}"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Value" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Column2}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource WarningTextBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </DockPanel>
                </Grid>

                <!-- ═══ Group Policy View (GPResult-style scrollable document) ═══ -->
                <DockPanel Visibility="{Binding CurrentMode, Converter={StaticResource ModeToVis}, ConverterParameter=GroupPolicy}">
                    <!-- Top header bar with search -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource SurfaceBrush}"
                            Padding="8,4"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="12,0,0,0">
                                <!-- Info icon with scope popup -->
                                <Button x:Name="GpInfoButton" 
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Padding="4,2" Margin="0,0,8,0"
                                        ToolTip="Policy scope info"
                                        Click="GpInfoButton_Click">
                                    <Grid Width="18" Height="18">
                                        <Ellipse Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.2" Fill="Transparent" />
                                        <TextBlock Text="i" FontSize="11" FontStyle="Italic" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="0,-1,0,0" />
                                    </Grid>
                                </Button>
                                <Popup x:Name="GpInfoPopup" PlacementTarget="{Binding ElementName=GpInfoButton}"
                                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                                    <Border Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="6"
                                            Padding="14,10" Margin="4">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" />
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock Text="Policy Scope" FontWeight="SemiBold" FontSize="13"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"
                                                       Margin="0,0,0,6">
                                                Shows registry-based policies only:
                                            </TextBlock>
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                                       Margin="12,0,0,2" Text="&#x2022;  Administrative Templates" />
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                                       Margin="12,0,0,2" Text="&#x2022;  Security Options (with registry paths)" />
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                                       Margin="12,0,0,8" Text="&#x2022;  Extra Registry Settings" />
                                            <TextBlock Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"
                                                       Margin="0,0,0,6">
                                                Does not include:
                                            </TextBlock>
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                                       Margin="12,0,0,2" Text="&#x2022;  Password / Account Lockout policies" />
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                                       Margin="12,0,0,2" Text="&#x2022;  Audit Configuration" />
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                                       Margin="12,0,0,2" Text="&#x2022;  User Rights Assignment" />
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                                       Margin="12,0,0,2" Text="&#x2022;  Scripts (Startup / Shutdown)" />
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                                       Margin="12,0,0,0" Text="&#x2022;  User-scoped (HKCU) policies" />
                                        </StackPanel>
                                    </Border>
                                </Popup>

                                <TextBlock Text="Search:" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11" Margin="0,0,6,0" />
                                <TextBox Text="{Binding GpSearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                         Width="200" Padding="6,3"
                                         VerticalAlignment="Center"
                                         FontSize="12"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         Background="{DynamicResource BackgroundBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}" />
                            </StackPanel>
                            <TextBlock Text="{Binding GroupPolicyHeader}"
                                       FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </DockPanel>
                    </Border>

                    <!-- Scrollable document of section headers + policy rows -->
                    <ListBox ItemsSource="{Binding GroupPolicyDocRows}"
                             SelectedItem="{Binding SelectedGroupPolicyRow}"
                             Background="{DynamicResource BackgroundBrush}"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.Resources>
                            <!-- Section header template -->
                            <DataTemplate x:Key="SectionHeaderTemplate">
                                <Border Background="{DynamicResource SurfaceLightBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0" Margin="0,8,0,0">
                                    <DockPanel>
                                        <!-- Accent left-edge bar -->
                                        <Border DockPanel.Dock="Left"
                                                Width="4"
                                                Background="{DynamicResource AccentBrush}" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Margin="8,6"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="11">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="({0})">
                                                    <Binding Path="SettingCount" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Text="{Binding CategoryPath}"
                                                   FontWeight="SemiBold"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="8,6"
                                                   TextTrimming="CharacterEllipsis" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>

                            <!-- Policy row template -->
                            <DataTemplate x:Key="PolicyRowTemplate">
                                <Grid Margin="12,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding PolicyName}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,3">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SettingValue}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,3">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>

                            <!-- List child row template (indented under enabledList parent) -->
                            <DataTemplate x:Key="ListChildRowTemplate">
                                <Grid Margin="36,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding PolicyName}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,3">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SettingValue}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,3">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListBox.Resources>

                        <ListBox.ItemTemplateSelector>
                            <helpers:GpDocumentTemplateSelector
                                SectionHeaderTemplate="{StaticResource SectionHeaderTemplate}"
                                PolicyRowTemplate="{StaticResource PolicyRowTemplate}"
                                ListChildRowTemplate="{StaticResource ListChildRowTemplate}" />
                        </ListBox.ItemTemplateSelector>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="Transparent"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource SelectionActiveBrush}" />
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True" />
                                                        <Condition Property="IsSelected" Value="False" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource SurfaceHoverBrush}" />
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <!-- Make section header rows non-selectable -->
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                        <Setter Property="IsHitTestVisible" Value="True" />
                                        <Setter Property="Focusable" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>

            </Grid>

            <!-- Detail pane splitter -->
            <GridSplitter Grid.Row="3"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

            <!-- ═══ Detail Pane ═══ -->
            <Border Grid.Row="4"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,0">
                <DockPanel>
                    <!-- Registry path -->
                    <TextBox DockPanel.Dock="Top"
                             Text="{Binding DetailRegistryPath, Mode=OneWay}"
                             IsReadOnly="True"
                             FontSize="11"
                             Background="{DynamicResource SurfaceLightBrush}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="0,0,0,1"
                             Padding="8,4" />

                    <!-- Value detail -->
                    <TextBox Text="{Binding DetailValueText, Mode=OneWay}"
                             Style="{DynamicResource MonoTextBoxStyle}" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
