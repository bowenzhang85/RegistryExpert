<Window x:Class="RegistryExpert.Wpf.Views.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:RegistryExpert.Wpf.Helpers"
        Title="Search Registry"
        Width="950" Height="650"
        MinWidth="700" MinHeight="500"
        Style="{DynamicResource ModernWindowStyle}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <helpers:ValueImageKeyConverter x:Key="ValueImageKeyConverter" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
    </Window.InputBindings>

    <DockPanel>

        <!-- ═══════════════════════════════════════════════════════════════
             Status Bar (Bottom)
             ═══════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{Binding StatusBrush}"
                       FontSize="12" />
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Top Bar: Search box + buttons + checkbox
             ═══════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel>
                <!-- Right side: Match whole word checkbox -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <Rectangle Width="1" Height="20"
                               Fill="{DynamicResource BorderBrush}" Margin="0,0,12,0" />
                    <CheckBox Content="Match whole word"
                              IsChecked="{Binding MatchWholeWord}"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              VerticalAlignment="Center" />
                </StackPanel>

                <!-- Buttons -->
                <Button DockPanel.Dock="Right"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibilityConverter}}"
                        Style="{DynamicResource AccentButtonStyle}"
                        Foreground="{DynamicResource ErrorBrush}"
                        MinWidth="80" Margin="8,0,0,0"
                        Padding="16,6" />

                <Button DockPanel.Dock="Right"
                        Content="Search"
                        Command="{Binding SearchCommand}"
                        Visibility="{Binding IsSearching, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                        Style="{DynamicResource AccentButtonStyle}"
                        MinWidth="80" Margin="8,0,0,0"
                        Padding="16,6" />

                <!-- Search label + text box -->
                <TextBlock DockPanel.Dock="Left"
                           Text="Search for:"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />

                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13"
                         Padding="8,5"
                         VerticalAlignment="Center"
                         AutomationProperties.Name="Search term">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Main Content: Results + Preview (split vertically)
             ═══════════════════════════════════════════════════════════════ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" MinHeight="100" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1*" MinHeight="80" />
            </Grid.RowDefinitions>

            <!-- Results area -->
            <DockPanel Grid.Row="0">
                <!-- Results header -->
                <Border DockPanel.Dock="Top"
                        Style="{DynamicResource SectionHeaderBorderStyle}">
                    <TextBlock Text="Results"
                               Style="{DynamicResource SectionHeaderStyle}"
                               Padding="0" />
                </Border>

                <!-- Load More button -->
                <Border DockPanel.Dock="Bottom"
                        Visibility="{Binding CanLoadMore, Converter={StaticResource BoolToVisibilityConverter}}"
                        Padding="0,6">
                    <Button Content="{Binding LoadMoreText}"
                            Command="{Binding LoadMoreCommand}"
                            Style="{DynamicResource AccentButtonStyle}"
                            HorizontalAlignment="Center"
                            Padding="20,6"
                            MinWidth="130" />
                </Border>

                <!-- Results grid + empty state -->
                <Grid>
                    <!-- Results DataGrid -->
                <DataGrid x:Name="ResultsGrid"
                          ItemsSource="{Binding Results}"
                          SelectedItem="{Binding SelectedResult}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          CanUserResizeRows="False"
                          MouseDoubleClick="ResultsGrid_MouseDoubleClick"
                          Tag="{Binding}"
                          AutomationProperties.Name="Search results">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Copy Path" InputGestureText="Ctrl+C"
                                      Command="{Binding PlacementTarget.Tag.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="Copy Value"
                                      Command="{Binding PlacementTarget.Tag.CopyValueCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <Separator />
                            <MenuItem Header="Navigate to Key"
                                      Command="{Binding PlacementTarget.Tag.NavigateCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <!-- Key Path with icon -->
                        <DataGridTemplateColumn Header="Key Path" Width="4*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="8,2">
                                        <Image Source="{Binding ImageKey, Converter={StaticResource ValueImageKeyConverter}}"
                                               Width="16" Height="16"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Margin="0,0,6,0"
                                               VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding KeyPath}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Name -->
                        <DataGridTemplateColumn Header="Name" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Details}"
                                               Margin="8,2"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Type -->
                        <DataGridTemplateColumn Header="Type" Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MatchType}"
                                               Margin="8,2"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Data -->
                        <DataGridTemplateColumn Header="Data" Width="3.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Data}"
                                               Margin="8,2"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                    <!-- Empty state message -->
                    <TextBlock Text="No results yet — enter a search term above"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Results.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>

            <!-- GridSplitter -->
            <GridSplitter Grid.Row="1"
                          Height="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Preview panel -->
            <DockPanel Grid.Row="2" Margin="12,8">
                <TextBlock DockPanel.Dock="Top"
                           Text="Registry Value Preview"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="12"
                           Margin="0,0,0,4" />

                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding PreviewPath}"
                           Foreground="{DynamicResource AccentBrush}"
                           FontFamily="Consolas"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,6" />

                <RichTextBox x:Name="PreviewRichTextBox"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Background="{DynamicResource SurfaceBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1"
                             Padding="8,6" />
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
