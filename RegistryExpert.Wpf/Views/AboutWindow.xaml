<Window x:Class="RegistryExpert.Wpf.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Registry Expert"
        Width="480" Height="490"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource ModernWindowStyle}"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource BackgroundBrush}" Padding="32,24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- Icon + Title + Version -->
                <RowDefinition Height="Auto" />  <!-- Description -->
                <RowDefinition Height="Auto" />  <!-- Author -->
                <RowDefinition Height="Auto" />  <!-- Feedback -->
                <RowDefinition Height="Auto" />  <!-- Privacy -->
                <RowDefinition Height="*" />     <!-- Spacer -->
                <RowDefinition Height="Auto" />  <!-- Supported hives -->
                <RowDefinition Height="Auto" />  <!-- Close button -->
            </Grid.RowDefinitions>

            <!-- Icon + Title + Version -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <Image Source="/Assets/registry.png"
                       Width="64" Height="64"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Top"
                       Margin="0,0,16,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Registry Expert"
                               FontFamily="Segoe UI"
                               FontWeight="SemiBold"
                               FontSize="22"
                               Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock x:Name="VersionLabel"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- Description -->
            <TextBlock Grid.Row="1"
                       Text="A lightweight tool for viewing and analyzing&#x0a;offline Windows registry hive files."
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="13"
                       LineHeight="20"
                       Margin="0,0,0,20" />

            <!-- Author section -->
            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <TextBlock Text="Author"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontWeight="SemiBold"
                           FontSize="10"
                           Margin="0,0,0,4" />
                <TextBlock Text="Bowen Zhang"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="13"
                           Margin="0,0,0,4" />
                <TextBlock FontSize="13">
                    <Hyperlink x:Name="EmailLink"
                               Click="EmailLink_Click"
                               Foreground="{DynamicResource AccentBrush}"
                               TextDecorations="None">
                        bowenzhang@microsoft.com
                    </Hyperlink>
                </TextBlock>
            </StackPanel>

            <!-- Feedback section -->
            <StackPanel Grid.Row="3" Margin="0,0,0,12">
                <TextBlock Text="Feedback"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontWeight="SemiBold"
                           FontSize="10"
                           Margin="0,0,0,6" />
                <Button Content="Submit Feedback"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Click="SubmitFeedback_Click"
                        HorizontalAlignment="Left"
                        Padding="16,6" />
            </StackPanel>

            <!-- Privacy link -->
            <TextBlock Grid.Row="4" FontSize="13" Margin="0,0,0,16">
                <Hyperlink x:Name="PrivacyLink"
                           Click="PrivacyLink_Click"
                           Foreground="{DynamicResource AccentBrush}"
                           TextDecorations="None">
                    Data Protection Notice
                </Hyperlink>
            </TextBlock>

            <!-- Supported hives -->
            <TextBlock Grid.Row="6"
                       Text="Supported Hives: NTUSER.DAT, SAM, SECURITY, SOFTWARE,&#x0a;SYSTEM, USRCLASS.DAT, Amcache.hve"
                       Foreground="{DynamicResource TextDisabledBrush}"
                       FontSize="8"
                       LineHeight="12"
                       Margin="0,0,0,16" />

            <!-- Close button -->
            <Button Grid.Row="7"
                    Content="Close"
                    Style="{DynamicResource AccentButtonStyle}"
                    Width="100"
                    HorizontalAlignment="Center"
                    Click="CloseButton_Click" />
        </Grid>
    </Border>
</Window>
