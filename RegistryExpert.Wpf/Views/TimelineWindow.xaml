<Window x:Class="RegistryExpert.Wpf.Views.TimelineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RegistryExpert.Wpf.ViewModels"
        xmlns:helpers="clr-namespace:RegistryExpert.Wpf.Helpers"
        Title="Timeline View - Registry Keys by Last Modified"
        Width="1000" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Style="{DynamicResource ModernWindowStyle}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
        <helpers:BindingProxy x:Key="Proxy" Data="{Binding}" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Filter panel -->
            <RowDefinition Height="*" />      <!-- DataGrid + detail -->
            <RowDefinition Height="Auto" />   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 0: Filter Panel
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <StackPanel>
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Hive selector (only if multiple hives loaded) -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4"
                                Visibility="{Binding ShowHiveSelector, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Hive:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{Binding HiveNames}"
                                  SelectedIndex="{Binding SelectedHiveIndex}"
                                  Width="140" />
                    </StackPanel>

                    <!-- Time filter -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                        <TextBlock Text="Time:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{Binding TimeFilterOptions}"
                                  SelectedIndex="{Binding SelectedTimeFilterIndex}"
                                  Width="160" />
                    </StackPanel>

                    <!-- Limit -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                        <TextBlock Text="Show:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{Binding LimitOptions}"
                                  SelectedIndex="{Binding SelectedLimitIndex}"
                                  Width="90" />
                    </StackPanel>

                    <!-- Scan button -->
                    <Button Content="{Binding ScanButtonText}"
                            Style="{DynamicResource AccentButtonStyle}"
                            Command="{Binding ScanCommand}"
                            MinWidth="80" Padding="16,6"
                            Margin="0,0,8,4" />

                    <!-- Export button -->
                    <Button Content="Export"
                            Style="{DynamicResource AccentButtonStyle}"
                            Command="{Binding ExportCommand}"
                            MinWidth="70" Padding="16,6"
                            Margin="0,0,8,4" />

                    <!-- Browse Logs button -->
                    <Button Content="Browse Logs..."
                            Style="{DynamicResource AccentButtonStyle}"
                            Command="{Binding BrowseLogsCommand}"
                            MinWidth="115" Padding="16,6"
                            Margin="0,0,8,4" />

                    <!-- TxLog filter checkbox -->
                    <CheckBox Content="TX Log changes only"
                              IsChecked="{Binding TxLogFilterChecked}"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              VerticalAlignment="Center"
                              Margin="8,0,0,4"
                              Visibility="{Binding ShowTxLogFilter, Converter={StaticResource BoolToVis}}" />
                </WrapPanel>

                <!-- Custom date range (visible when "Custom Range..." selected) -->
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                            Visibility="{Binding ShowCustomDateRange, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="From:"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <DatePicker SelectedDate="{Binding CustomFromDate}"
                                Width="130" Margin="0,0,12,0" />
                    <TextBlock Text="To:"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <DatePicker SelectedDate="{Binding CustomToDate}"
                                Width="130" />
                </StackPanel>

                <!-- Search box -->
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         Background="{DynamicResource BackgroundBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Padding="6,4"
                         Margin="0,6,0,0">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Tag" Value="Search key path..." />
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 1: Content (DataGrid + Detail Panel)
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />        <!-- DataGrid + Load More -->
                <RowDefinition Height="Auto" />     <!-- Detail panel -->
            </Grid.RowDefinitions>

            <!-- DataGrid -->
            <DockPanel Grid.Row="0">
                <!-- Load More button (docked at bottom) -->
                <Button DockPanel.Dock="Bottom"
                        Content="{Binding LoadMoreText}"
                        Command="{Binding LoadMoreCommand}"
                        Style="{DynamicResource AccentButtonStyle}"
                        Height="30" Margin="10,4"
                        Visibility="{Binding ShowLoadMore, Converter={StaticResource BoolToVis}}" />

                <DataGrid x:Name="TimelineGrid"
                          ItemsSource="{Binding DisplayedEntries}"
                          SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          AlternationCount="2"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          Background="{DynamicResource BackgroundBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          BorderThickness="0"
                          MouseDoubleClick="TimelineGrid_MouseDoubleClick"
                          AutomationProperties.Name="Timeline entries">

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="Tag"
                                    Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Navigate to Key"
                                                  Command="{Binding PlacementTarget.Tag.NavigateCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Copy Path"
                                                  Command="{Binding PlacementTarget.Tag.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <!-- Last Modified -->
                        <DataGridTextColumn Header="Last Modified" Width="180"
                                            Binding="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                            SortMemberPath="LastModified">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                    <Setter Property="Margin" Value="4,2" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Key Path -->
                        <DataGridTextColumn Header="Key Path" Width="*"
                                            Binding="{Binding DisplayPath}"
                                            SortMemberPath="DisplayPath">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                    <Setter Property="Margin" Value="4,2" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Change Type (template column for colored text, visibility via Proxy) -->
                        <DataGridTemplateColumn Header="Change" Width="100"
                                                SortMemberPath="ChangeTypeText"
                                                Visibility="{Binding Data.HasTxLogColumns, Source={StaticResource Proxy}, Converter={StaticResource BoolToVis}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ChangeTypeText}" Margin="4,2">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ChangeTypeBrushKey}" Value="DiffAddedBrush">
                                                        <Setter Property="Foreground" Value="{DynamicResource DiffAddedBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ChangeTypeBrushKey}" Value="DiffRemovedBrush">
                                                        <Setter Property="Foreground" Value="{DynamicResource DiffRemovedBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ChangeTypeBrushKey}" Value="WarningBrush">
                                                        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Details -->
                        <DataGridTextColumn Header="Details" Width="180"
                                            Binding="{Binding Details}"
                                            Visibility="{Binding Data.HasTxLogColumns, Source={StaticResource Proxy}, Converter={StaticResource BoolToVis}}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                    <Setter Property="Margin" Value="4,2" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <!-- Detail Panel (transaction log value changes) -->
            <Border Grid.Row="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    MaxHeight="250"
                    Visibility="{Binding ShowDetailPanel, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Detail header -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10,6">
                        <TextBlock Text="{Binding DetailHeaderText}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>

                    <!-- Detail DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding DetailItems}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="{DynamicResource BackgroundBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderThickness="0"
                              AutomationProperties.Name="Transaction log detail">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Value Name" Width="180"
                                                Binding="{Binding ValueName}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        <Setter Property="Margin" Value="4,2" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Type" Width="100"
                                                Binding="{Binding ValueType}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                        <Setter Property="Margin" Value="4,2" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Change (template column for colored text) -->
                            <DataGridTemplateColumn Header="Change" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ChangeTypeText}" Margin="4,2">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ChangeTypeBrushKey}" Value="DiffAddedBrush">
                                                            <Setter Property="Foreground" Value="{DynamicResource DiffAddedBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ChangeTypeBrushKey}" Value="DiffRemovedBrush">
                                                            <Setter Property="Foreground" Value="{DynamicResource DiffRemovedBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ChangeTypeBrushKey}" Value="WarningBrush">
                                                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Before" Width="*"
                                                Binding="{Binding OldData}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                        <Setter Property="Margin" Value="4,2" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="After" Width="*"
                                                Binding="{Binding NewData}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        <Setter Property="Margin" Value="4,2" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 2: Status Bar
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,6">
            <DockPanel>
                <!-- Spinning arc (visible while scanning) -->
                <Path DockPanel.Dock="Right"
                      Width="14" Height="14"
                      Margin="8,0,0,0"
                      Data="M 5,1 A 4,4 0 1 1 1,5"
                      StrokeThickness="1.5"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Stretch="Uniform"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform>
                        <RotateTransform Angle="0" />
                    </Path.RenderTransform>
                    <Path.Style>
                        <Style TargetType="Path">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="Stroke" Value="{DynamicResource AccentBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowProgress}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="SpinStoryboard">
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                    From="0" To="360"
                                                    Duration="0:0:0.8"
                                                    RepeatBehavior="Forever" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="SpinStoryboard" />
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>

                <!-- Status text -->
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
