<Window x:Class="RegistryExpert.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RegistryExpert.Wpf.ViewModels"
        xmlns:helpers="clr-namespace:RegistryExpert.Wpf.Helpers"
        Title="{Binding WindowTitle}"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="600"
        Style="{DynamicResource ModernWindowStyle}"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragEnter"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <helpers:ValueImageKeyConverter x:Key="ValueImageKeyConverter" />
        <helpers:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter" />
        <CollectionViewSource x:Key="GroupedBookmarks" Source="{Binding Bookmarks}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="HiveType" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenHiveCommand}" />
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding ExportKeyCommand}" />
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding OpenSearchCommand}" />
        <KeyBinding Key="F5" Command="{Binding OpenAnalyzeCommand}" />
        <KeyBinding Key="I" Modifiers="Ctrl" Command="{Binding OpenStatisticsCommand}" />
        <KeyBinding Key="M" Modifiers="Ctrl" Command="{Binding OpenCompareCommand}" />
        <KeyBinding Key="T" Modifiers="Ctrl" Command="{Binding OpenTimelineCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelLoadCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Menu -->
            <RowDefinition Height="Auto" />  <!-- Toolbar -->
            <RowDefinition Height="*" />     <!-- Content -->
            <RowDefinition Height="Auto" />  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 0: Menu Bar
             ═══════════════════════════════════════════════════════════════ -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Hive..." InputGestureText="Ctrl+O"
                          Command="{Binding OpenHiveCommand}" />
                <MenuItem x:Name="UnloadHiveMenu" Header="_Unload Hive"
                          SubmenuOpened="UnloadHiveMenu_SubmenuOpened">
                    <MenuItem Header="(no hives loaded)" IsEnabled="False" />
                </MenuItem>
                <Separator />
                <MenuItem Header="_Export Key..." InputGestureText="Ctrl+E"
                          Command="{Binding ExportKeyCommand}" />
                <Separator />
                <MenuItem Header="E_xit" InputGestureText="Alt+F4"
                          Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Dark Theme"
                          Command="{Binding SwitchThemeCommand}"
                          CommandParameter="Dark" />
                <MenuItem Header="_Light Theme"
                          Command="{Binding SwitchThemeCommand}"
                          CommandParameter="Light" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Search..." InputGestureText="Ctrl+F"
                          Command="{Binding OpenSearchCommand}" />
                <Separator />
                <MenuItem Header="_Analyze" InputGestureText="F5"
                          Command="{Binding OpenAnalyzeCommand}" />
                <MenuItem Header="S_tatistics" InputGestureText="Ctrl+I"
                          Command="{Binding OpenStatisticsCommand}" />
                <MenuItem Header="Ti_meline" InputGestureText="Ctrl+T"
                          Command="{Binding OpenTimelineCommand}" />
                <MenuItem Header="_Compare" InputGestureText="Ctrl+M" Command="{Binding OpenCompareCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Check for _Updates" IsEnabled="False" />
                <Separator />
                <MenuItem Header="_About" IsEnabled="False" />
            </MenuItem>
        </Menu>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 1: Toolbar
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <!-- Open -->
                <Button Style="{DynamicResource ToolbarButtonStyle}"
                        Command="{Binding OpenHiveCommand}"
                        ToolTip="Open Hive (Ctrl+O)"
                        AutomationProperties.Name="Open Hive">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="pack://application:,,,/Assets/registry_icon_open.png"
                               Width="32" Height="32" RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Open" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>

                <!-- Separator -->
                <Rectangle Style="{DynamicResource ToolbarSeparatorStyle}" />

                <!-- Search -->
                <Button Style="{DynamicResource ToolbarButtonStyle}"
                        Command="{Binding OpenSearchCommand}"
                        ToolTip="Search (Ctrl+F)"
                        AutomationProperties.Name="Search">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="pack://application:,,,/Assets/registry_icon_search.png"
                               Width="32" Height="32" RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Search" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>

                <!-- Analyze -->
                <Button Style="{DynamicResource ToolbarButtonStyle}"
                        Command="{Binding OpenAnalyzeCommand}"
                        ToolTip="Analyze (F5)"
                        AutomationProperties.Name="Analyze">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="pack://application:,,,/Assets/registry_icon_analyze.png"
                               Width="32" Height="32" RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Analyze" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>

                <!-- Separator -->
                <Rectangle Style="{DynamicResource ToolbarSeparatorStyle}" />

                <!-- Statistics -->
                <Button Style="{DynamicResource ToolbarButtonStyle}"
                        Command="{Binding OpenStatisticsCommand}"
                        ToolTip="Statistics (Ctrl+I)"
                        AutomationProperties.Name="Statistics">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="pack://application:,,,/Assets/registry_icon_statistics.png"
                               Width="32" Height="32" RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Statistics" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>

                <!-- Compare -->
                <Button Style="{DynamicResource ToolbarButtonStyle}"
                        Command="{Binding OpenCompareCommand}"
                        ToolTip="Compare (Ctrl+M)"
                        AutomationProperties.Name="Compare">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="pack://application:,,,/Assets/registry_icon_compare.png"
                               Width="32" Height="32" RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Compare" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>

                <!-- Timeline -->
                <Button Style="{DynamicResource ToolbarButtonStyle}"
                        Command="{Binding OpenTimelineCommand}"
                        ToolTip="Timeline (Ctrl+T)"
                        AutomationProperties.Name="Timeline">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="pack://application:,,,/Assets/registry_icon_timeline.png"
                               Width="32" Height="32" RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Timeline" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 2: Content Area
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Background="{DynamicResource BackgroundBrush}">

            <!-- Layer 1: Welcome Panel (visible when no hives loaded) -->
            <Border Visibility="{Binding HasLoadedHives, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="48,40">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.3" Color="Black" />
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="pack://application:,,,/Assets/registry.png"
                               Width="64" Height="64"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16" />
                        <TextBlock Text="Registry Expert"
                                   Style="{DynamicResource TitleStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="Drag and drop a registry hive file to get started"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,24" />
                        <Button Style="{DynamicResource WelcomeButtonStyle}"
                                Command="{Binding OpenHiveCommand}"
                                HorizontalAlignment="Center">
                            <TextBlock Text="Open Hive Files" />
                        </Button>
                        <TextBlock Text="Supports SYSTEM, SOFTWARE, SAM, SECURITY, NTUSER.DAT, and more"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,0" />
                    </StackPanel>
                </Border>
            </Border>

            <!-- Layer 2: Main Content (visible when hives are loaded) -->
            <Grid Visibility="{Binding HasLoadedHives, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="560" MinWidth="200" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Vertical Splitter -->
                <GridSplitter Grid.Column="1" Width="5"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext" />

                <!-- ═══ Left Panel: Bookmarks + Tree ═══ -->
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" /> <!-- Bookmark area -->
                        <ColumnDefinition Width="*" />   <!-- Tree area -->
                    </Grid.ColumnDefinitions>

                    <!-- Bookmark Panel -->
                    <Border Grid.Column="0"
                            Visibility="{Binding HasBookmarks, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,1,0">

                        <Grid>
                            <!-- Collapsed bookmark bar -->
                            <Border Visibility="{Binding IsBookmarkPanelExpanded, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                    Width="24" Cursor="Hand"
                                    MouseLeftButtonDown="BookmarkCollapsedBar_MouseDown"
                                    Background="Transparent"
                                    ToolTip="Show Bookmarks">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0,8,0,0">
        <!-- Bookmark ribbon icon (matches WinForms GDI+ drawn shape) -->
                        <Path Data="M 0,0 L 14,0 L 14,18 L 7,13 L 0,18 Z"
                              Fill="{DynamicResource AccentBrush}"
                              Width="14" Height="18"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,6" />
                                    <TextBlock Text="Bookmarks"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"
                                               RenderTransformOrigin="0.5,0.5">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="270" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Expanded bookmark panel -->
                            <Border Visibility="{Binding IsBookmarkPanelExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Width="160">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Bookmark header -->
                                    <Border Style="{DynamicResource SectionHeaderBorderStyle}">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right"
                                                    Content="✕"
                                                    FontSize="10"
                                                    Padding="4,2"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                                    Cursor="Hand"
                                                    Command="{Binding ToggleBookmarksCommand}"
                                                    ToolTip="Hide Bookmarks" />
                                            <TextBlock Text="Bookmarks"
                                                       Style="{DynamicResource SectionHeaderStyle}"
                                                       Padding="0" />
                                        </DockPanel>
                                    </Border>

                                    <!-- Bookmark list (grouped by hive) -->
                                    <ScrollViewer Grid.Row="1"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedBookmarks}}">
                                            <ItemsControl.GroupStyle>
                                                <GroupStyle>
                                                    <GroupStyle.HeaderTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       Padding="10,10,8,4"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </DataTemplate>
                                                    </GroupStyle.HeaderTemplate>
                                                </GroupStyle>
                                            </ItemsControl.GroupStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border x:Name="BookmarkBorder"
                                                            Background="Transparent"
                                                            CornerRadius="4"
                                                            Margin="6,1"
                                                            Padding="8,5"
                                                            Cursor="Hand"
                                                            MouseLeftButtonDown="BookmarkItem_MouseDown"
                                                            ToolTip="{Binding Path}">
                                                        <DockPanel>
                                                            <TextBlock Text="&#xE76C;"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,6,0" />
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </DockPanel>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <Trigger SourceName="BookmarkBorder" Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="BookmarkBorder" Property="Background"
                                                                    Value="{DynamicResource SurfaceHoverBrush}" />
                                                        </Trigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Tree Area -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Tree header -->
                        <Border Style="{DynamicResource SectionHeaderBorderStyle}">
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Style="{DynamicResource AccentButtonStyle}"
                                        Command="{Binding OpenHiveCommand}"
                                        Padding="8,2"
                                        FontSize="11"
                                        ToolTip="Load another hive file">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="pack://application:,,,/Assets/registry_icon_load-hive.png"
                                               Width="14" Height="14"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Margin="0,0,4,0" />
                                        <TextBlock Text="Load Hive" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="Registry Keys"
                                           Style="{DynamicResource SectionHeaderStyle}"
                                           Padding="0"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>

                        <!-- TreeView -->
                        <TreeView x:Name="RegistryTree" Grid.Row="1"
                                  ItemsSource="{Binding TreeRoots}"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                  SelectedItemChanged="RegistryTree_SelectedItemChanged"
                                  PreviewKeyDown="RegistryTree_PreviewKeyDown"
                                  AutomationProperties.Name="Registry keys">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                    <Setter Property="FontWeight" Value="{Binding IsRootNode, Converter={StaticResource BoolToFontWeightConverter}}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Tag"
                                            Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu>
                                                <ContextMenu.Resources>
                                                    <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
                                                </ContextMenu.Resources>
                                                <MenuItem Header="Copy Path"
                                                          Command="{Binding PlacementTarget.Tag.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          InputGestureText="Ctrl+Shift+C" />
                                                <Separator />
                                                <MenuItem Header="Export Key..."
                                                          Command="{Binding PlacementTarget.Tag.ExportKeyCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          InputGestureText="Ctrl+E" />
                                                <Separator Visibility="{Binding PlacementTarget.DataContext.IsRootNode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}" />
                                                <MenuItem Header="Unload Hive"
                                                          Command="{Binding PlacementTarget.Tag.CloseHiveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.DisplayName, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Visibility="{Binding PlacementTarget.DataContext.IsRootNode, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}" />
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TreeViewItem">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <!-- Hive separator line (between loaded hives) -->
                                                    <Rectangle x:Name="HiveSeparator"
                                                               Grid.Row="0"
                                                               Height="1"
                                                               Fill="{DynamicResource BorderBrush}"
                                                               Margin="0,4"
                                                               Visibility="Collapsed" />
                                                    <!-- Header row: hover/selection only applies here -->
                                                    <Border x:Name="HeaderBorder"
                                                            Grid.Row="1"
                                                            Background="Transparent"
                                                            Padding="4,2"
                                                            SnapsToDevicePixels="True">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <ToggleButton x:Name="Expander"
                                                                          Grid.Column="0"
                                                                          ClickMode="Press"
                                                                          IsChecked="{Binding Path=IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                          Focusable="False"
                                                                          Width="16" Height="16"
                                                                          Margin="0,0,2,0">
                                                                <ToggleButton.Style>
                                                                    <Style TargetType="ToggleButton">
                                                                        <Setter Property="Focusable" Value="False" />
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="ToggleButton">
                                                                                    <Border Background="Transparent" Width="16" Height="16">
                                                                                        <Path x:Name="ExpandPath"
                                                                                              Data="M 4,2 L 10,6 L 4,10 Z"
                                                                                              Fill="{DynamicResource TextSecondaryBrush}"
                                                                                              HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center"
                                                                                              SnapsToDevicePixels="True" />
                                                                                    </Border>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsChecked" Value="True">
                                                                                            <Setter TargetName="ExpandPath"
                                                                                                    Property="Data"
                                                                                                    Value="M 2,4 L 6,10 L 10,4 Z" />
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Style>
                                                                </ToggleButton.Style>
                                                            </ToggleButton>
                                                            <ContentPresenter x:Name="PART_Header"
                                                                              Grid.Column="1"
                                                                              ContentSource="Header"
                                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                              VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                    <!-- Children panel -->
                                                    <ItemsPresenter x:Name="ItemsHost"
                                                                    Grid.Row="2"
                                                                    Margin="18,0,0,0"
                                                                    Visibility="Collapsed" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsExpanded" Value="True">
                                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                                    </Trigger>
                                                    <Trigger Property="HasItems" Value="False">
                                                        <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                                    </Trigger>
                                                    <!-- Hover only on the header border -->
                                                    <Trigger SourceName="HeaderBorder" Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="HeaderBorder" Property="Background"
                                                                Value="{DynamicResource SurfaceHoverBrush}" />
                                                    </Trigger>
                                                    <!-- Selection highlights the header border -->
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="HeaderBorder" Property="Background"
                                                                Value="{DynamicResource SelectionActiveBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                                    </Trigger>
                                                    <!-- Show separator line between hives -->
                                                    <DataTrigger Binding="{Binding ShowSeparator}" Value="True">
                                                        <Setter TargetName="HiveSeparator" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{x:Static helpers:NativeIconHelper.FolderIcon}"
                                           Width="16" Height="16"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding DisplayName}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </Grid>

                <!-- ═══ Right Panel: Values + Details ═══ -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="100" />
                    </Grid.RowDefinitions>

                    <!-- Horizontal Splitter -->
                    <GridSplitter Grid.Row="1" Height="5"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  ResizeBehavior="PreviousAndNext" />

                    <!-- Values Area -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Values header -->
                        <Border Style="{DynamicResource SectionHeaderBorderStyle}">
                            <TextBlock Text="Values"
                                       Style="{DynamicResource SectionHeaderStyle}"
                                       Padding="0" />
                        </Border>

                        <!-- DataGrid -->
                        <DataGrid x:Name="ValuesGrid" Grid.Row="1"
                                  ItemsSource="{Binding Values}"
                                  SelectedItem="{Binding SelectedValue, Mode=TwoWay}"
                                  AlternationCount="2"
                                  MouseDoubleClick="ValuesGrid_MouseDoubleClick"
                                   AutomationProperties.Name="Registry values">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Name" Width="200" MinWidth="100"
                                                        SortMemberPath="Name">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                                <Image Source="{Binding ImageKey, Converter={StaticResource ValueImageKeyConverter}}"
                                                       Width="16" Height="16"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding Name}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Type" Width="110"
                                                    Binding="{Binding Type}" />
                                <DataGridTextColumn Header="Data" Width="*"
                                                    Binding="{Binding Data}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Setter Property="Tag"
                                            Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu>
                                                <MenuItem Header="Copy Value"
                                                          Command="{Binding PlacementTarget.Tag.CopyValueCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          InputGestureText="Ctrl+C" />
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>

                        <!-- Empty state message -->
                        <TextBlock Grid.Row="1"
                                   Text="Select a key to view its values"
                                   Foreground="{DynamicResource TextDisabledBrush}"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Values.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Details Area -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Details header -->
                        <Border Style="{DynamicResource SectionHeaderBorderStyle}">
                            <TextBlock Text="Details"
                                       Style="{DynamicResource SectionHeaderStyle}"
                                       Padding="0" />
                        </Border>

                        <!-- Details TextBox -->
                        <TextBox Grid.Row="1"
                                 Style="{DynamicResource MonoTextBoxStyle}"
                                 Text="{Binding DetailsText, Mode=OneWay}" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 3: Status Bar
             ═══════════════════════════════════════════════════════════════ -->
        <StatusBar Grid.Row="3">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel LastChildFill="True" />
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <!-- Right side items -->
            <StatusBarItem DockPanel.Dock="Right" Padding="8,2">
                <StackPanel Orientation="Horizontal">
                    <!-- Cancel button (visible during loading) -->
                    <Button Content="Cancel"
                            Command="{Binding CancelLoadCommand}"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{DynamicResource AccentBrush}"
                            Cursor="Hand"
                            Padding="8,2"
                            Margin="0,0,8,0" />

                    <!-- Progress bar (visible during loading) -->
                    <ProgressBar Width="120" Height="12"
                                 Value="{Binding LoadProgress}"
                                 Minimum="0" Maximum="100"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                                 Margin="0,0,12,0" />

                    <!-- Hive status indicator -->
                    <TextBlock Text="{Binding HiveStatusText}"
                               Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StatusBarItem>

            <!-- Left side: status text (fills remaining space) -->
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"
                           TextTrimming="CharacterEllipsis" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
