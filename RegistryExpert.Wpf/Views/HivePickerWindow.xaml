<Window x:Class="RegistryExpert.Wpf.Views.HivePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Hives to Load"
        Width="560" Height="420"
        MinWidth="400" MinHeight="300"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource ModernWindowStyle}"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource BackgroundBrush}" Padding="24,20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- Header text -->
                <RowDefinition Height="*" />     <!-- Hive list -->
                <RowDefinition Height="Auto" />  <!-- Select All / None -->
                <RowDefinition Height="Auto" />  <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock x:Name="HeaderText"
                       Grid.Row="0"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="13"
                       Margin="0,0,0,12" />

            <!-- Hive list with checkboxes -->
            <Border Grid.Row="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,0,0,12">
                <ListBox x:Name="HiveList"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0" />

                                <TextBlock Grid.Column="1"
                                           Text="{Binding TypeName}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           MinWidth="100"
                                           Margin="0,0,12,0" />

                                <TextBlock Grid.Column="2"
                                           Text="{Binding RelativePath}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding RelativePath}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Select All / Select None -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Margin="0,0,0,16">
                <Button Content="Select All"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Click="SelectAll_Click"
                        Padding="12,6"
                        Margin="0,0,8,0" />
                <Button Content="Select None"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Click="SelectNone_Click"
                        Padding="12,6" />
            </StackPanel>

            <!-- Load / Cancel buttons -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="LoadButton"
                        Content="Load Selected"
                        Style="{DynamicResource AccentButtonStyle}"
                        Click="LoadButton_Click"
                        Padding="20,8"
                        MinWidth="120"
                        Margin="0,0,8,0" />
                <Button Content="Cancel"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Click="CancelButton_Click"
                        Padding="20,8"
                        MinWidth="80" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
